<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
    {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.password_enabled -%}
    <meta name="robots" content="noindex, nofollow">
  {%- endif -%}

  <!-- Anti-flash: apply theme before paint -->
  <script>
    (function(){
      var t=localStorage.getItem('activeedge-theme')||
        (window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');
      document.documentElement.setAttribute('data-theme',t);
    })();
  </script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- CSS Design Tokens & Base -->
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'component-header.css' | asset_url | stylesheet_tag }}
  {{ 'component-hero.css' | asset_url | stylesheet_tag }}
  {{ 'section-homepage.css' | asset_url | stylesheet_tag }}
  {{ 'component-product-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
  {{ 'component-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-footer.css' | asset_url | stylesheet_tag }}
  {{ 'theme-dark.css' | asset_url | stylesheet_tag }}

  <!-- Inline CSS custom properties from theme settings -->
  <style>
    :root {
      --color-accent-1: {{ settings.colors_accent_1 }};
      --color-accent-2: {{ settings.colors_accent_2 }};
      --color-bg-1: {{ settings.colors_background_1 }};
      --color-bg-2: {{ settings.colors_background_2 }};
      --color-text: {{ settings.colors_text }};
    }
  </style>

  {{ content_for_header }}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  <a class="skip-to-content" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  {%- render 'cart-drawer' -%}

  <!-- Overlay for cart drawer / mobile menu -->
  <div class="overlay" id="overlay" aria-hidden="true"></div>

  <!-- Core Scripts -->
  <script src="{{ 'global.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer></script>
  <script src="{{ 'search.js' | asset_url }}" defer></script>
  <script src="{{ 'animations.js' | asset_url }}" defer></script>
  <script src="{{ 'theme-toggle.js' | asset_url }}" defer></script>

</body>
</html>
