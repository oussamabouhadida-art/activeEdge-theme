<section class="section-blog page-width">

  <div class="section-blog__header">
    <h1 class="section-blog__title">{{ blog.title }}</h1>
    {%- if section.settings.show_description and blog.description != blank -%}
      <p class="section-blog__desc">{{ blog.description }}</p>
    {%- endif -%}
  </div>

  {%- paginate blog.articles by section.settings.articles_per_page -%}
    <div class="blog-grid">
      {%- for article in blog.articles -%}
        <article class="blog-card">
          {%- if article.image -%}
            <a href="{{ article.url }}" class="blog-card__image-link" tabindex="-1" aria-hidden="true">
              <div class="blog-card__image-wrap">
                <img
                  src="{{ article.image | image_url: width: 640 }}"
                  srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 640 }} 640w"
                  sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                  class="blog-card__image"
                >
              </div>
            </a>
          {%- endif -%}

          <div class="blog-card__content">
            {%- if section.settings.show_tags and article.tags.size > 0 -%}
              <div class="blog-card__tags">
                {%- for tag in article.tags limit: 2 -%}
                  <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="blog-card__tag">{{ tag }}</a>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <h2 class="blog-card__title">
              <a href="{{ article.url }}" class="blog-card__title-link">{{ article.title }}</a>
            </h2>

            {%- if section.settings.show_excerpt and article.excerpt != blank -%}
              <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 140 }}</p>
            {%- endif -%}

            <div class="blog-card__meta">
              <time class="blog-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                {{ article.published_at | date: '%d %B %Y' }}
              </time>
              {%- if section.settings.show_author -%}
                <span class="blog-card__author">{{ 'blog.posted_by' | t: author: article.author }}</span>
              {%- endif -%}
            </div>

            <a href="{{ article.url }}" class="blog-card__cta">
              {{ 'blog.read_more' | t }}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- render 'pagination', paginate: paginate -%}
  {%- endpaginate -%}

</section>

<style>
.section-blog {
  padding: var(--section-padding) var(--container-padding);
}
.section-blog__header {
  text-align: center;
  margin-bottom: var(--space-12);
}
.section-blog__title {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  color: var(--color-green);
  margin-bottom: var(--space-4);
}
.section-blog__desc {
  color: var(--color-text-medium);
  max-width: 560px;
  margin: 0 auto;
  line-height: var(--line-height-relaxed);
}
.blog-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-8);
}
@media (min-width: 768px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .blog-grid { grid-template-columns: repeat(3, 1fr); }
}
.blog-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-white);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition), transform var(--transition);
  display: flex;
  flex-direction: column;
}
.blog-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.blog-card__image-wrap {
  aspect-ratio: 16/9;
  overflow: hidden;
}
.blog-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 400ms ease;
}
.blog-card:hover .blog-card__image { transform: scale(1.04); }
.blog-card__content {
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  flex: 1;
}
.blog-card__tags {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}
.blog-card__tag {
  font-size: var(--font-size-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-mid);
  text-decoration: none;
  background: var(--color-pale);
  padding: 2px var(--space-2);
  border-radius: var(--radius-full);
}
.blog-card__title {
  font-family: var(--font-heading);
  font-size: var(--font-size-xl);
  font-weight: 700;
  line-height: var(--line-height-snug);
}
.blog-card__title-link {
  color: var(--color-text);
  text-decoration: none;
  transition: color var(--transition);
}
.blog-card__title-link:hover { color: var(--color-green); }
.blog-card__excerpt {
  font-size: var(--font-size-sm);
  color: var(--color-text-medium);
  line-height: var(--line-height-relaxed);
}
.blog-card__meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-top: auto;
}
.blog-card__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-mid);
  text-decoration: none;
  transition: color var(--transition), gap var(--transition);
}
.blog-card__cta:hover { color: var(--color-green); gap: var(--space-3); }
</style>

{% schema %}
{
  "name": "Blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles par page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Afficher la description du blog",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Afficher l'extrait",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Afficher l'auteur",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Afficher les tags",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Liste d'articles"
    }
  ]
}
{% endschema %}
