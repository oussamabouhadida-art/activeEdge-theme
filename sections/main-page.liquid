<article class="page-content page-width">
  {%- render 'breadcrumb' -%}
  <div class="page-content__inner rte">
    {%- if section.settings.show_title -%}
      <h1 class="page-content__title">{{ page.title }}</h1>
    {%- endif -%}
    <div class="page-content__body">
      {{ page.content }}
    </div>
  </div>
</article>

<style>
.page-content {
  padding: var(--section-padding) var(--container-padding);
}
.page-content__inner {
  max-width: 760px;
  margin: 0 auto;
}
.page-content__title {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  color: var(--color-green);
  margin-bottom: var(--space-8);
  line-height: var(--line-height-tight);
}
/* Rich text styles */
.rte h2 {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-forest);
  margin: var(--space-10) 0 var(--space-4);
}
.rte h3 {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--color-green);
  margin: var(--space-8) 0 var(--space-3);
}
.rte p { margin-bottom: var(--space-4); line-height: var(--line-height-relaxed); }
.rte ul, .rte ol { padding-left: var(--space-6); margin-bottom: var(--space-4); }
.rte li { margin-bottom: var(--space-2); line-height: var(--line-height-relaxed); }
.rte a { color: var(--color-mid); text-decoration: underline; }
.rte a:hover { color: var(--color-green); }
.rte strong { font-weight: 600; }
.rte blockquote {
  border-left: 4px solid var(--color-mid);
  padding: var(--space-4) var(--space-6);
  margin: var(--space-6) 0;
  background: var(--color-pale);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  font-style: italic;
  color: var(--color-forest);
}
.rte img {
  border-radius: var(--radius-md);
  margin: var(--space-6) 0;
}
.rte table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: var(--space-6);
}
.rte th, .rte td {
  padding: var(--space-3) var(--space-4);
  border: 1px solid var(--color-mint);
  text-align: left;
}
.rte th {
  background: var(--color-pale);
  font-weight: 600;
  font-family: var(--font-heading);
}
</style>

{% schema %}
{
  "name": "Contenu de page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Afficher le titre",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Contenu de page"
    }
  ]
}
{% endschema %}
