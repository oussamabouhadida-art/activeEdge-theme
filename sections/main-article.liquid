<article class="article-page page-width" itemscope itemtype="http://schema.org/BlogPosting">

  {%- render 'breadcrumb' -%}

  <header class="article-page__header">
    {%- if section.settings.show_tags and article.tags.size > 0 -%}
      <div class="article-page__tags">
        {%- for tag in article.tags -%}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-page__tag">{{ tag }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <h1 class="article-page__title" itemprop="name headline">{{ article.title }}</h1>

    <div class="article-page__meta">
      <time class="article-page__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
        {{ article.published_at | date: '%d %B %Y' }}
      </time>
      {%- if section.settings.show_author -%}
        <span class="article-page__author" itemprop="author" itemscope itemtype="http://schema.org/Person">
          <span itemprop="name">{{ article.author }}</span>
        </span>
      {%- endif -%}
    </div>
  </header>

  {%- if article.image -%}
    <div class="article-page__image-wrap">
      <img
        src="{{ article.image | image_url: width: 1200 }}"
        srcset="{{ article.image | image_url: width: 768 }} 768w, {{ article.image | image_url: width: 1200 }} 1200w"
        sizes="(min-width: 1280px) 900px, 100vw"
        alt="{{ article.image.alt | default: article.title | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ article.image.width }}"
        height="{{ article.image.height }}"
        class="article-page__image"
        itemprop="image"
      >
    </div>
  {%- endif -%}

  <div class="article-page__body rte" itemprop="articleBody">
    {{ article.content }}
  </div>

  {%- if section.settings.show_share -%}
    <div class="article-page__share">
      <p class="article-page__share-label">Partager :</p>
      <div class="article-page__share-buttons">
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm" aria-label="Partager sur Facebook">Facebook</a>
        <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm" aria-label="Partager sur X/Twitter">Twitter</a>
      </div>
    </div>
  {%- endif -%}

  <div class="article-page__nav">
    <a href="{{ blog.url }}" class="btn btn--outline">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      {{ 'blog.back_to_blog' | t }}
    </a>
  </div>

  {%- if blog.comments_enabled? and section.settings.show_comments -%}
    <div class="article-page__comments">
      {%- if article.comments_count > 0 -%}
        <h2 class="article-page__comments-title">{{ article.comments_count }} commentaire{% if article.comments_count > 1 %}s{% endif %}</h2>
        {%- paginate article.comments by 10 -%}
          {%- for comment in article.comments -%}
            <div class="article-comment" id="comment-{{ comment.id }}">
              <div class="article-comment__meta">
                <span class="article-comment__author">{{ comment.author }}</span>
                <time class="article-comment__date" datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">{{ comment.created_at | date: '%d %B %Y' }}</time>
              </div>
              <div class="article-comment__body rte">{{ comment.content }}</div>
            </div>
          {%- endfor -%}
          {%- render 'pagination', paginate: paginate -%}
        {%- endpaginate -%}
      {%- endif -%}
    </div>
  {%- endif -%}

</article>

<style>
.article-page {
  padding: var(--section-padding) var(--container-padding);
  max-width: 860px;
  margin: 0 auto;
}
.article-page__header { margin-bottom: var(--space-8); }
.article-page__tags {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
  margin-bottom: var(--space-4);
}
.article-page__tag {
  font-size: var(--font-size-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-mid);
  text-decoration: none;
  background: var(--color-pale);
  padding: 2px var(--space-3);
  border-radius: var(--radius-full);
  transition: background var(--transition);
}
.article-page__tag:hover { background: var(--color-mint); }
.article-page__title {
  font-family: var(--font-heading);
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  color: var(--color-forest);
  line-height: var(--line-height-tight);
  margin-bottom: var(--space-4);
}
.article-page__meta {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}
.article-page__image-wrap {
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--space-10);
  aspect-ratio: 16/9;
}
.article-page__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.article-page__body { margin-bottom: var(--space-10); }
.article-page__share {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-6) 0;
  border-top: 1px solid var(--color-mint);
  margin-bottom: var(--space-6);
}
.article-page__share-label {
  font-weight: 600;
  font-size: var(--font-size-sm);
  color: var(--color-text-medium);
}
.article-page__share-buttons {
  display: flex;
  gap: var(--space-2);
}
.article-page__nav {
  border-top: 1px solid var(--color-mint);
  padding-top: var(--space-6);
}
.article-comment {
  padding: var(--space-6) 0;
  border-bottom: 1px solid var(--color-pale);
}
.article-comment__meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}
.article-comment__author {
  font-weight: 600;
  color: var(--color-green);
}
.article-comment__date {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}
</style>

{% schema %}
{
  "name": "Article de blog",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Afficher l'auteur",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Afficher les tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share",
      "label": "Afficher les boutons de partage",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_comments",
      "label": "Afficher les commentaires",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Article de blog"
    }
  ]
}
{% endschema %}
