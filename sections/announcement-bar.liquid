{%- if section.settings.show_announcement -%}
<div class="announcement-bar" role="region" aria-label="{{ 'sections.announcement_bar.label' | t }}">
  <div class="announcement-bar__inner">
    {%- if section.blocks.size > 0 -%}
      <div class="announcement-bar__slider" id="announcement-slider">
        {%- for block in section.blocks -%}
          <div class="announcement-bar__slide" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link">
            {%- endif -%}
            <span class="announcement-bar__text">{{ block.settings.text }}</span>
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="announcement-bar__text">{{ section.settings.default_text }}</p>
    {%- endif -%}
  </div>
</div>
{%- endif -%}

<style>
  .announcement-bar {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-align: center;
    padding: 0.5rem 1rem;
    position: relative;
    z-index: 100;
  }
  .announcement-bar a { color: inherit; text-decoration: none; }
  .announcement-bar a:hover { text-decoration: underline; }
  .announcement-bar__inner { max-width: 1200px; margin: 0 auto; overflow: hidden; }
  .announcement-bar__slider { display: flex; }
  .announcement-bar__slide {
    min-width: 100%;
    animation: announcementSlide {{ section.blocks.size | times: 4 }}s linear infinite;
  }
  @keyframes announcementSlide {
    0%, 30% { transform: translateX(0); }
    33%, 63% { transform: translateX(-100%); }
    66%, 96% { transform: translateX(-200%); }
    100% { transform: translateX(0); }
  }
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 5,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "default_text",
      "label": "Default message",
      "default": "🌿 Livraison gratuite dès 50€ • Retours faciles 30 jours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1B4332"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#D8F3DC"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "🌿 Livraison gratuite dès 50€"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "🌿 Livraison gratuite dès 50€ — Bouge libre."
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "↩ Retours faciles sous 30 jours"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "🍃 Matériaux éco-responsables"
          }
        }
      ]
    }
  ]
}
{% endschema %}
