<section class="featured-collection section-padding">
  <div class="page-width">
    <div class="section-header section-header--with-cta" data-reveal="fade-up">
      <div>
        {%- if section.settings.heading != blank -%}
          <h2 class="section-title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="section-subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all -%}
        {%- assign view_url = section.settings.collection != blank | default: '/collections/all' -%}
        <a href="{{ collections[section.settings.collection].url | default: '/collections/all' }}" class="btn btn--outline">
          {{ 'sections.featured_collection.view_all' | t }}
        </a>
      {%- endif -%}
    </div>

    {%- assign featured_collection = collections[section.settings.collection] -%}
    {%- assign show_products = false -%}
    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      {%- assign show_products = true -%}
    {%- endif -%}

    <div class="product-carousel" data-reveal-stagger=".product-carousel__item" data-reveal-step="60">
      <div class="product-carousel__track">

        {%- if show_products -%}
          {%- for product in featured_collection.products limit: section.settings.products_count -%}
            <div class="product-carousel__item">
              {%- render 'product-card', product: product, show_quick_add: section.settings.show_quick_add -%}
            </div>
          {%- endfor -%}

        {%- else -%}
          {%- for i in (1..section.settings.products_count) -%}
            <div class="product-carousel__item">
              <div class="product-card product-card--placeholder">
                <div class="product-card__image-wrap">
                  <div class="product-card__image-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 9 6 6M15 9l-6 6"/></svg>
                  </div>
                </div>
                <div class="product-card__info">
                  <p class="product-card__vendor">ActiveEdge</p>
                  <p class="product-card__title">{{ 'sections.featured_collection.onboarding_title' | t }}</p>
                  <p class="product-card__price">29,90 €</p>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

      </div>

      {%- if show_products and featured_collection.products_count > 1 -%}
        <div class="product-carousel__controls">
          <button class="product-carousel__btn product-carousel__btn--prev" aria-label="{{ 'accessibility.previous' | t }}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="product-carousel__dots"></div>
          <button class="product-carousel__btn product-carousel__btn--next" aria-label="{{ 'accessibility.next' | t }}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nos best-sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Les favoris de la communauté ActiveEdge"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "settings": {
        "heading": "Nos best-sellers"
      }
    }
  ]
}
{% endschema %}
