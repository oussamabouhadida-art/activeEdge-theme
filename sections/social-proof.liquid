<section class="social-proof section-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-header">
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        {%- if section.settings.rating_count != blank -%}
          <div class="social-proof__aggregate">
            <div class="social-proof__stars">
              {%- for i in (1..5) -%}
                {%- render 'icon-star', filled: true -%}
              {%- endfor -%}
            </div>
            <span class="social-proof__rating-text">
              {{ section.settings.rating }} / 5 — {{ section.settings.rating_count }} {{ 'sections.social_proof.reviews' | t }}
            </span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="social-proof__grid" data-reveal-stagger=".social-proof__card" data-reveal-step="100">
      {%- for block in section.blocks -%}
        <div class="social-proof__card" {{ block.shopify_attributes }}>
          <div class="social-proof__card-stars">
            {%- for i in (1..block.settings.rating) -%}
              {%- render 'icon-star', filled: true -%}
            {%- endfor -%}
          </div>
          {%- if block.settings.quote != blank -%}
            <blockquote class="social-proof__quote">
              "{{ block.settings.quote }}"
            </blockquote>
          {%- endif -%}
          <div class="social-proof__author">
            {%- if block.settings.avatar != blank -%}
              <img
                src="{{ block.settings.avatar | image_url: width: 48, height: 48, crop: 'center' }}"
                alt="{{ block.settings.name }}"
                class="social-proof__avatar"
                width="48"
                height="48"
                loading="lazy"
              >
            {%- else -%}
              <div class="social-proof__avatar social-proof__avatar--placeholder">
                {{ block.settings.name | slice: 0 | upcase }}
              </div>
            {%- endif -%}
            <div class="social-proof__author-info">
              <span class="social-proof__name">{{ block.settings.name }}</span>
              {%- if block.settings.location != blank -%}
                <span class="social-proof__location">{{ block.settings.location }}</span>
              {%- endif -%}
            </div>
          </div>
          {%- if block.settings.verified -%}
            <span class="social-proof__verified">
              {%- render 'icon-check' -%}
              {{ 'sections.social_proof.verified' | t }}
            </span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social proof",
  "max_blocks": 9,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ce qu'ils disent d'ActiveEdge"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Average rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Review count",
      "default": "1 248"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "Franchement bluffant. Je cours tous les matins avec ma ceinture ActiveEdge — elle ne bouge pas d'un millimètre."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Sophie M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Lyon, France"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar (optional)"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified purchase",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Franchement bluffant. Je cours tous les matins avec ma ceinture ActiveEdge — elle ne bouge pas d'un millimètre.",
            "name": "Sophie M.",
            "location": "Lyon, France",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Design top, qualité au rendez-vous. J'ai reçu de nombreux compliments lors de mes sorties vélo.",
            "name": "Thomas K.",
            "location": "Paris, France",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Livraison ultra rapide, emballage éco soigné, produit encore mieux qu'en photo. Je recommande !",
            "name": "Camille B.",
            "location": "Bordeaux, France",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
